# 機密情報・環境依存ファイル
.env
*.env.local
!*.env.local.example

# Terraform
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/**/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/**/terraform.tfstate
terraform/**/terraform.tfstate.backup
terraform/*.tfvars
terraform/**/*.tfvars
!terraform/*.tfvars.example
!terraform/**/*.tfvars.example

# GCPサービスアカウントキー
*.json
!package*.json
!tsconfig*.json
!firebase.json
!frontend/messages/*.json
!marketing/*.json

# Node.js
node_modules/
dist/
.next/
out/

# ビルド成果物
*.js.map
build/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# ログ
*.log
npm-debug.log*
frontend/.env.local
frontend/node_modules/
frontend/.next/

# スクリーンショット・一時画像（public/ 以下に置いてしまわないように）
# 使用中の画像: ogp.png / logo_mekiki_research.png / favicon.ico は除外対象外
frontend/public/*.png
!frontend/public/ogp.png
!frontend/public/logo_mekiki_research.png
frontend/public/*.jpg
frontend/public/*.gif
frontend/public/*.bmp
frontend/public/*.tiff

# SEO ページ用ライフスタイル画像（スクリプトで動的生成・git 管理外）
frontend/public/seo-images/

# Terraform プロバイダーバイナリ（サブディレクトリも含む全 .terraform）
terraform/**/.terraform/
terraform/**/.terraform.lock.hcl
