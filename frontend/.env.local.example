# サイトのベースURL（OGP・sitemap・canonical URL に使用）
NEXT_PUBLIC_SITE_URL=https://mekiki-research.com

# ローカル開発: バックエンドAPI URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# 本番: Cloud Run の URL
# NEXT_PUBLIC_API_URL=https://realestate-api-2hctlfcy6a-an.a.run.app

# Firebase Authentication (Firebaseコンソールから取得)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Lemon Squeezy（フロントエンドから参照する場合。現実装では不要）
# NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID=...

# e-Stat API（将来性スコア・人口動態）
# 取得先: https://www.e-stat.go.jp/ → ユーザ登録後にアプリケーションID発行
# 未設定の場合は人口スコアが暫定値にフォールバック
ESTAT_API_KEY=

# PostHog 行動ログ計測（省略可。未設定時は計測しない）
# 取得先: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
