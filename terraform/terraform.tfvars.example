# このファイルをコピーして terraform.tfvars を作成し、実際の値を入力してください
# cp terraform.tfvars.example terraform.tfvars

project_id             = "your-gcp-project-id"
region                 = "asia-northeast1"
cache_bucket_name      = "your-project-id-realestate-cache"
bq_dataset_id          = "realestate_cache"
cloud_run_service_name = "realestate-api"
cache_ttl_days         = 30
