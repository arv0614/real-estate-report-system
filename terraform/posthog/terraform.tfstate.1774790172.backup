    {
      "mode": "managed",
      "type": "posthog_hog_function",
      "name": "survey_to_waitlist",
      "provider": "provider[\"registry.terraform.io/posthog/posthog\"]",
      "instances": [
        {
          "status": "tainted",
          "schema_version": 0,
          "attributes": {
            "description": "limit_reached survey 送信時にメールアドレスをバックエンド waitlist API へ転送",
            "enabled": true,
            "execution_order": null,
            "filters_json": "{\"events\":[{\"id\":\"survey sent\",\"name\":\"survey sent\",\"type\":\"events\"}]}",
            "hog": "let email := event.properties['$survey_response_1']\nif (empty(email)) {\n    return\n}\nlet res := fetch(inputs.webhook_url, {\n    'method': 'POST',\n    'headers': {\n        'Content-Type': 'application/json',\n        'X-Webhook-Secret': inputs.webhook_secret\n    },\n    'body': {\n        'email': email,\n        'survey_id': event.properties['$survey_id'],\n        'survey_name': event.properties['$survey_name'],\n        'distinct_id': event.distinct_id\n    }\n})\nif (res.status \u003e= 400) {\n    throw Error(concat('Webhook error: ', toString(res.status)))\n}",
            "icon_url": null,
            "id": "019d39bc-3c3a-0000-17ed-55854a4928be",
            "inputs_json": null,
            "mappings_json": null,
            "masking_json": null,
            "name": "Survey Response → Waitlist Webhook",
            "project_id": "361030",
            "sensitive_inputs_json": "{}",
            "template_id": null,
            "type": "destination"
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "sensitive_inputs_json"
              }
            ]
          ],
          "identity_schema_version": 0
        }
      ]
    },
