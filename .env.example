# ============================================
# GCP 設定
# ============================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1

# Firebase プロジェクトID（GCPプロジェクトIDと異なる場合のみ設定）
# 省略時は GCP_PROJECT_ID が使われる
FIREBASE_PROJECT_ID=your-firebase-project-id

# GCS バケット名（キャッシュ用）
GCS_CACHE_BUCKET=your-project-id-realestate-cache

# BigQuery
BQ_DATASET=realestate_cache
BQ_TABLE=property_data

# ============================================
# Cloud Run サービス名
# ============================================
CLOUD_RUN_SERVICE_NAME=realestate-api

# ============================================
# バックエンド設定
# ============================================
PORT=8080
NODE_ENV=development

# キャッシュ有効期限（日数）
CACHE_TTL_DAYS=30

# ============================================
# 国交省 不動産情報ライブラリAPI
# ============================================
MLIT_API_KEY=your-mlit-api-key
MLIT_API_BASE_URL=https://www.reinfolib.mlit.go.jp/ex-api/external

# ============================================
# Stripe 決済
# ============================================
# テスト用キー: Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...

# Webhook署名シークレット: stripe listen --forward-to ... 実行時に表示される
# 本番は Stripe Dashboard > Webhooks で取得
STRIPE_WEBHOOK_SECRET=whsec_...

# サブスクリプション Price ID: Stripe Dashboard > Products で作成したProプランの価格ID
STRIPE_PRICE_ID=price_...

# 決済完了・キャンセル後のリダイレクト先（本番はCloud RunのURL）
STRIPE_SUCCESS_URL=http://localhost:3000/?payment=success
STRIPE_CANCEL_URL=http://localhost:3000/?payment=cancel
