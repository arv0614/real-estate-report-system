# ============================================
# GCP 設定
# ============================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1

# Firebase プロジェクトID（GCPプロジェクトIDと異なる場合のみ設定）
# 省略時は GCP_PROJECT_ID が使われる
FIREBASE_PROJECT_ID=your-firebase-project-id

# GCS バケット名（キャッシュ用）
GCS_CACHE_BUCKET=your-project-id-realestate-cache

# BigQuery
BQ_DATASET=realestate_cache
BQ_TABLE=property_data

# ============================================
# Cloud Run サービス名
# ============================================
CLOUD_RUN_SERVICE_NAME=realestate-api

# ============================================
# バックエンド設定
# ============================================
PORT=8080
NODE_ENV=development

# キャッシュ有効期限（日数）
CACHE_TTL_DAYS=30

# ============================================
# 国交省 不動産情報ライブラリAPI
# ============================================
MLIT_API_KEY=your-mlit-api-key
MLIT_API_BASE_URL=https://www.reinfolib.mlit.go.jp/ex-api/external

# ============================================
# Lemon Squeezy 決済
# ============================================
# API キー: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=...

# ストアID: Lemon Squeezy ダッシュボード > Stores
LEMONSQUEEZY_STORE_ID=...

# バリアントID（Proプラン商品のVariant ID）
LEMONSQUEEZY_VARIANT_ID=...

# Webhook 署名シークレット: Lemon Squeezy > Settings > Webhooks で設定
LEMONSQUEEZY_WEBHOOK_SECRET=...

# 決済完了後のリダイレクト先（本番はCloud RunのフロントエンドURL）
LEMONSQUEEZY_SUCCESS_URL=http://localhost:3000/?payment=success

# ============================================
# Google Tag Manager
# ============================================
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
